generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum BriefStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

model User {
  id               String       @id @default(cuid())
  name             String
  email            String       @unique
  passwordHash     String
  role             Role         @default(ADMIN)
  expertiseTags    String[]     @default([])
  historicalRating Float        @default(3.0)
  currentLoad      Int          @default(0)
  maxLoad          Int          @default(3)
  assignments      Assignment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Trend {
  id               String   @id @default(cuid())
  title            String
  source           String
  rawData          Json?
  trendScore       Float    @default(0)
  relevanceScore   Float    @default(0)
  opportunityScore Float    @default(0)
  aiExplanation    String?
  briefs           Brief[]
  createdAt        DateTime @default(now())

  @@index([opportunityScore])
}

model Brief {
  id               String       @id @default(cuid())
  trend            Trend        @relation(fields: [trendId], references: [id])
  trendId          String
  summary          String?
  audienceAnalysis String?
  angle            String?
  seoKeywords      String[]     @default([])
  h1               String?
  headingStructure Json?
  wordCount        Int?
  status           BriefStatus  @default(PENDING)
  assignments      Assignment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Assignment {
  id         String           @id @default(cuid())
  brief      Brief            @relation(fields: [briefId], references: [id])
  briefId    String
  writer     User             @relation(fields: [writerId], references: [id])
  writerId   String
  status     AssignmentStatus @default(ASSIGNED)
  assignedAt DateTime         @default(now())
  draft      Draft?
}

model Draft {
  id           String     @id @default(cuid())
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId String     @unique
  content      String
  submittedAt  DateTime?
  review       Review?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Review {
  id                   String   @id @default(cuid())
  draft                Draft    @relation(fields: [draftId], references: [id])
  draftId              String   @unique
  seoComplianceScore   Float    @default(0)
  readabilityScore     Float    @default(0)
  keywordCoverage      Float    @default(0)
  missingSections      String[] @default([])
  briefComplianceScore Float    @default(0)
  aiNotes              String?
  createdAt            DateTime @default(now())
}